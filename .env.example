# Gemini (reuses Clo's key)
GOOGLE_API_KEY=
RUBI_MODEL=gemini-3-flash-preview

# The business's Linq line (+1 904 874 1368) and the Linq partner key
LINQ_API_KEY=
LINQ_FROM=+19048741368

# Firebase service account (same project as Clo; data lives in rubi_* collections)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# Live availability. Resy's Incapsula edge 500s datacenter IPs, so route /4/find through the same
# residential proxy luna-api uses. Copy that value here (any of the three names works).
RUBI_AVAIL_PROXY=
# AVAIL_PROXY_URL=
# RESY_PROXY=
# Optional: OpenTable support (Akamai-walled) activates only if a Scrapfly key is present.
SCRAPFLY_API_KEY=

# Customer context engine (per-tenant memory). Off by default , demo path unchanged until flipped.
RUBI_CONTEXT_ENABLED=0
# Static bearer token for /api/v1 (web dashboard backend). Firebase ID tokens also accepted.
RUBI_API_TOKEN=

# Governance: emergency pause, per-tenant daily message backstop, missed-call text-back (needs telephony).
RUBI_PAUSED=0
RUBI_TENANT_DAILY_CAP=500
RUBI_MISSED_CALL_ENABLED=0
# Cache only (Firestore is source of truth). db 2 keeps rubi keys away from Clo's db 0.
RUBI_REDIS_URL=redis://localhost:6379/2
